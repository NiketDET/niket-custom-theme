<script
  src="{{ 'marquee.js' | asset_url }}"
  type="module"
></script>

<section
  class="benefit-badge-marquee benefit-badge-marquee--{{ section.id }}"
  style="
    --bbm-bg: {{ section.settings.background_color }};
    --bbm-accent-color: {{ section.settings.accent_color }};
    --bbm-accent-height: {{ section.settings.accent_height }}px;
    --bbm-text-color: {{ section.settings.text_color }};
    --bbm-icon-color: {{ section.settings.icon_color }};
    --bbm-max-width: {{ section.settings.section_max_width }}px;
    --bbm-padding-inline: {{ section.settings.padding_inline }}px;
    --bbm-padding-top: {{ section.settings.padding_top }}px;
    --bbm-padding-bottom: {{ section.settings.padding_bottom }}px;
    --bbm-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --bbm-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --bbm-gap: {{ section.settings.item_gap }}px;
    --bbm-item-gap: {{ section.settings.icon_gap }}px;
    --bbm-font-size: {{ section.settings.text_size_desktop }}px;
    --bbm-font-size-mobile: {{ section.settings.text_size_mobile }}px;
    --bbm-icon-size: {{ section.settings.icon_size_desktop }}px;
    --bbm-icon-size-mobile: {{ section.settings.icon_size_mobile }}px;
    --bbm-letter-spacing: {{ section.settings.letter_spacing }}em;
    --bbm-font-weight: {{ section.settings.font_weight }};
    --bbm-radius: {{ section.settings.item_radius }}px;
    --bbm-speed-factor: {{ section.settings.speed_factor }};
  "
>
  <marquee-component
    class="benefit-badge-marquee__track"
    data-speed-factor="{{ section.settings.speed_factor }}"
    data-movement-direction="{{ section.settings.movement_direction }}"
    style="--marquee-direction: {{ section.settings.movement_direction }};"
  >
    <div
      class="benefit-badge-marquee__wrapper"
      ref="wrapper"
    >
      <div
        class="benefit-badge-marquee__content"
        ref="content"
      >
        <div class="benefit-badge-marquee__repeated-items">
          {% for block in section.blocks %}
            {% liquid
              assign has_link = false
              if block.settings.link != blank
                assign has_link = true
              endif
            %}

            {% if has_link %}
              <a
                class="benefit-badge-marquee__item benefit-badge-marquee__item--link"
                href="{{ block.settings.link }}"
                {% if block.settings.open_new_tab %}
                  target="_blank"
                  rel="noopener noreferrer"
                {% endif %}
                aria-label="{{ block.settings.label | escape }}"
                {{ block.shopify_attributes }}
              >
            {% else %}
              <div
                class="benefit-badge-marquee__item"
                {{ block.shopify_attributes }}
              >
            {% endif %}

            {% if block.settings.icon != 'none' or block.settings.custom_icon != blank %}
              <span class="benefit-badge-marquee__icon-wrap">
                {% render 'icon-or-image',
                  icon: block.settings.icon,
                  image_upload: block.settings.custom_icon,
                  width: section.settings.icon_size_desktop,
                  class_name: 'benefit-badge-marquee__icon'
                %}
              </span>
            {% endif %}

            <span class="benefit-badge-marquee__label">{{ block.settings.label }}</span>

            {% if has_link %}
              </a>
            {% else %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </marquee-component>
</section>

{% stylesheet %}
  .benefit-badge-marquee {
    position: relative;
    width: 100%;
    background: var(--bbm-bg);
    border-top: var(--bbm-accent-height) solid var(--bbm-accent-color);
    overflow: hidden;
  }

  .benefit-badge-marquee__track {
    display: block;
    width: 100%;
    overflow: hidden;
    background: var(--bbm-bg);
    padding-top: var(--bbm-padding-top);
    padding-bottom: var(--bbm-padding-bottom);
    padding-inline: max(min(var(--bbm-padding-inline), 5vw), calc((100vw - var(--bbm-max-width)) / 2));
  }

  .benefit-badge-marquee__wrapper {
    display: flex;
    gap: var(--bbm-gap);
    width: fit-content;
    white-space: nowrap;
  }

  .benefit-badge-marquee__content {
    min-width: max-content;
    display: flex;
    gap: var(--bbm-gap);
  }

  .benefit-badge-marquee__repeated-items {
    min-width: max-content;
    display: flex;
    align-items: center;
    gap: var(--bbm-gap);
    padding-inline: 0;
    background: var(--bbm-bg);
  }

  .benefit-badge-marquee__item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--bbm-item-gap);
    min-width: max-content;
    color: var(--bbm-text-color);
    text-decoration: none;
    border-radius: var(--bbm-radius);
  }

  .benefit-badge-marquee__item--link:hover {
    opacity: 0.9;
  }

  .benefit-badge-marquee__icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--bbm-icon-size);
    height: var(--bbm-icon-size);
    flex: 0 0 var(--bbm-icon-size);
    color: var(--bbm-icon-color);
  }

  .benefit-badge-marquee__icon {
    display: block;
    width: 100%;
    height: 100%;
    color: inherit;
    fill: currentColor;
    stroke: currentColor;
  }

  .benefit-badge-marquee__label {
    display: inline-block;
    color: var(--bbm-text-color);
    font-family: var(--font-subheading--family);
    font-style: var(--font-subheading--style);
    font-size: var(--bbm-font-size);
    font-weight: var(--bbm-font-weight);
    line-height: 1;
    letter-spacing: var(--bbm-letter-spacing);
    text-transform: uppercase;
  }

  @media (prefers-reduced-motion: no-preference) {
    .benefit-badge-marquee__track:not([data-disabled]) .benefit-badge-marquee__wrapper {
      animation: badge-marquee-motion var(--marquee-speed) linear infinite var(--marquee-direction);
    }
  }

  @keyframes badge-marquee-motion {
    to {
      transform: translate3d(calc(-50% - (var(--bbm-gap) / 2)), 0, 0);
    }
  }

  @media screen and (max-width: 749px) {
    .benefit-badge-marquee__track {
      padding-top: var(--bbm-padding-top-mobile);
      padding-bottom: var(--bbm-padding-bottom-mobile);
      padding-inline: 16px;
    }

    .benefit-badge-marquee__repeated-items {
      padding-inline: 0;
    }

    .benefit-badge-marquee__item {
      gap: max(6px, calc(var(--bbm-item-gap) - 2px));
    }

    .benefit-badge-marquee__icon-wrap {
      width: var(--bbm-icon-size-mobile);
      height: var(--bbm-icon-size-mobile);
      flex-basis: var(--bbm-icon-size-mobile);
    }

    .benefit-badge-marquee__label {
      font-size: var(--bbm-font-size-mobile);
    }
  }
{% endstylesheet %}

