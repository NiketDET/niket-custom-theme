{% liquid
  assign use_slider = false
  if section.settings.enable_slider and section.blocks.size > 1
    assign use_slider = true
  endif

  assign image_widths = '180, 240, 320, 420, 560, 720, 860, 1000, 1200'
  assign image_sizes = '(min-width: 1200px) 46vw, (min-width: 990px) 48vw, (min-width: 750px) 88vw, 94vw'
%}

<section
  id="SupplementHeroSlider-{{ section.id }}"
  class="supplement-hero-slider supplement-hero-slider--mobile-{{ section.settings.mobile_order }}{% if section.settings.figma_exact_mode %} supplement-hero-slider--figma{% endif %}"
  data-slider-enabled="{% if use_slider %}true{% else %}false{% endif %}"
  style="
    --shs-max-width: {{ section.settings.max_width }}px;
    --shs-min-height-desktop: {{ section.settings.section_height_desktop }}px;
    --shs-min-height-mobile: {{ section.settings.section_height_mobile }}px;
    --shs-padding-top: {{ section.settings.padding_top }}px;
    --shs-padding-bottom: {{ section.settings.padding_bottom }}px;
    --shs-padding-inline: {{ section.settings.padding_inline }}px;
    --shs-content-column: {{ section.settings.content_column }}fr;
    --shs-media-column: {{ section.settings.media_column }}fr;
    --shs-column-gap: {{ section.settings.columns_gap }}px;
    --shs-content-width: {{ section.settings.content_max_width }}px;
    --shs-top-bg: {{ section.settings.background_top }};
    --shs-bottom-bg: {{ section.settings.background_bottom }};
    --shs-bg-split: {{ section.settings.background_split }}%;
    --shs-heading-color: {{ section.settings.heading_color }};
    --shs-subheading-color: {{ section.settings.subheading_color }};
    --shs-body-color: {{ section.settings.text_color }};
    --shs-heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
    --shs-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --shs-subheading-size-desktop: {{ section.settings.subheading_size_desktop }}px;
    --shs-subheading-size-mobile: {{ section.settings.subheading_size_mobile }}px;
    --shs-body-size-desktop: {{ section.settings.body_size_desktop }}px;
    --shs-body-size-mobile: {{ section.settings.body_size_mobile }}px;
    --shs-heading-weight: {{ section.settings.heading_weight }};
    --shs-subheading-weight: {{ section.settings.subheading_weight }};
    --shs-body-weight: {{ section.settings.body_weight }};
    --shs-heading-line-height: {{ section.settings.heading_line_height }};
    --shs-subheading-line-height: {{ section.settings.subheading_line_height }};
    --shs-body-line-height: {{ section.settings.body_line_height }};
    --shs-subheading-gap: {{ section.settings.subheading_spacing_top }}px;
    --shs-button-gap: {{ section.settings.button_spacing_top }}px;
    --shs-button-bg: {{ section.settings.button_background }};
    --shs-button-text: {{ section.settings.button_text_color }};
    --shs-button-border: {{ section.settings.button_border_color }};
    --shs-button-hover-bg: {{ section.settings.button_hover_background }};
    --shs-button-hover-text: {{ section.settings.button_hover_text_color }};
    --shs-button-hover-border: {{ section.settings.button_hover_border_color }};
    --shs-button-size: {{ section.settings.button_text_size }}px;
    --shs-button-weight: {{ section.settings.button_font_weight }};
    --shs-button-radius: {{ section.settings.button_radius }}px;
    --shs-button-padding-y: {{ section.settings.button_padding_vertical }}px;
    --shs-button-padding-x: {{ section.settings.button_padding_horizontal }}px;
    --shs-button-min-width: {{ section.settings.button_min_width }}px;
    --shs-media-max-width: {{ section.settings.media_max_width }}px;
    --shs-media-overlap: {{ section.settings.image_overlap }}px;
    --shs-media-bottom-shift: {{ section.settings.media_bottom_shift }}px;
    --shs-media-align: {{ section.settings.media_alignment }};
    --shs-nav-size: {{ section.settings.nav_size }}px;
    --shs-nav-color: {{ section.settings.nav_color }};
    --shs-nav-bg: {{ section.settings.nav_background }};
  "
>
  <div class="supplement-hero-slider__inner">
    <div class="supplement-hero-slider__swiper{% unless use_slider %} supplement-hero-slider__swiper--static{% endunless %}{% if use_slider %} swiper{% endif %}">
      <div class="supplement-hero-slider__track{% if use_slider %} swiper-wrapper{% endif %}">
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            <article
              class="supplement-hero-slider__slide{% if use_slider %} swiper-slide{% endif %}"
              {{ block.shopify_attributes }}
            >
              <div class="supplement-hero-slider__layout">
                <div class="supplement-hero-slider__content supplement-hero-slider__content--{{ section.settings.text_alignment }}">
                  {% if block.settings.heading != blank %}
                    <h2 class="supplement-hero-slider__heading">{{ block.settings.heading }}</h2>
                  {% endif %}

                  {% if block.settings.subheading != blank %}
                    <p class="supplement-hero-slider__subheading">{{ block.settings.subheading }}</p>
                  {% endif %}

                  {% if block.settings.description != blank %}
                    <div class="supplement-hero-slider__description rte">{{ block.settings.description }}</div>
                  {% endif %}

                  {% if block.settings.button_label != blank %}
                    {% if block.settings.button_link != blank %}
                      <a class="supplement-hero-slider__button" href="{{ block.settings.button_link }}">
                        {{- block.settings.button_label -}}
                      </a>
                    {% else %}
                      <span class="supplement-hero-slider__button supplement-hero-slider__button--disabled">
                        {{- block.settings.button_label -}}
                      </span>
                    {% endif %}
                  {% endif %}
                </div>

                <div
                  class="supplement-hero-slider__media"
                  aria-label="{{ block.settings.heading | escape }}"
                  style="
                    --shs-block-media-horizontal: {{ block.settings.images_horizontal_position }};
                    --shs-block-media-vertical: {{ block.settings.images_vertical_position }};
                  "
                >
                  <div class="supplement-hero-slider__media-track">
                    {% if block.settings.image_1 != blank %}
                      <div
                        class="supplement-hero-slider__item supplement-hero-slider__item--1"
                      >
                        {{
                          block.settings.image_1
                          | image_url: width: 1200
                          | image_tag:
                            widths: image_widths,
                            sizes: image_sizes,
                            class: 'supplement-hero-slider__image',
                            loading: 'lazy',
                            alt: block.settings.alt_text_1
                        }}
                      </div>
                    {% endif %}

                    {% if block.settings.image_2 != blank %}
                      <div
                        class="supplement-hero-slider__item supplement-hero-slider__item--2"
                      >
                        {{
                          block.settings.image_2
                          | image_url: width: 1200
                          | image_tag:
                            widths: image_widths,
                            sizes: image_sizes,
                            class: 'supplement-hero-slider__image',
                            loading: 'lazy',
                            alt: block.settings.alt_text_2
                        }}
                      </div>
                    {% endif %}

                    {% if block.settings.image_3 != blank %}
                      <div
                        class="supplement-hero-slider__item supplement-hero-slider__item--3"
                      >
                        {{
                          block.settings.image_3
                          | image_url: width: 1200
                          | image_tag:
                            widths: image_widths,
                            sizes: image_sizes,
                            class: 'supplement-hero-slider__image',
                            loading: 'lazy',
                            alt: block.settings.alt_text_3
                        }}
                      </div>
                    {% endif %}

                    {% if block.settings.image_4 != blank %}
                      <div
                        class="supplement-hero-slider__item supplement-hero-slider__item--4"
                      >
                        {{
                          block.settings.image_4
                          | image_url: width: 1200
                          | image_tag:
                            widths: image_widths,
                            sizes: image_sizes,
                            class: 'supplement-hero-slider__image',
                            loading: 'lazy',
                            alt: block.settings.alt_text_4
                        }}
                      </div>
                    {% endif %}

                    {% if block.settings.image_1 == blank
                      and block.settings.image_2 == blank
                      and block.settings.image_3 == blank
                      and block.settings.image_4 == blank
                    %}
                      {% for i in (1..4) %}
                        <div
                          class="supplement-hero-slider__item supplement-hero-slider__item--{{ i }}"
                        >
                          {{
                            'image'
                            | placeholder_svg_tag: 'supplement-hero-slider__image supplement-hero-slider__image--placeholder'
                          }}
                        </div>
                      {% endfor %}
                    {% endif %}
                  </div>
                </div>
              </div>
            </article>
          {% endfor %}
        {% else %}
          <article class="supplement-hero-slider__slide{% if use_slider %} swiper-slide{% endif %}">
            <div class="supplement-hero-slider__layout">
              <div class="supplement-hero-slider__content supplement-hero-slider__content--left">
                <h2 class="supplement-hero-slider__heading">Supplements You Can Trust</h2>
                <p class="supplement-hero-slider__subheading">
                  IMPROVING THE QUALITY OF LIFE FOR OVER A QUARTER OF CENTURY
                </p>
                <a class="supplement-hero-slider__button" href="#">Shop Best Sellers</a>
              </div>
              <div class="supplement-hero-slider__media" aria-label="Supplements You Can Trust">
                <div class="supplement-hero-slider__media-track">
                  {% for i in (1..4) %}
                    <div
                      class="supplement-hero-slider__item supplement-hero-slider__item--{{ i }}"
                    >
                      {{
                        'image'
                        | placeholder_svg_tag: 'supplement-hero-slider__image supplement-hero-slider__image--placeholder'
                      }}
                    </div>
                  {% endfor %}
                </div>
              </div>
            </div>
          </article>
        {% endif %}
      </div>

      {% if use_slider and section.settings.show_navigation %}
        <button
          class="supplement-hero-slider__nav supplement-hero-slider__nav--prev"
          type="button"
          aria-label="Previous slide"
        >
          <span>&larr;</span>
        </button>
        <button
          class="supplement-hero-slider__nav supplement-hero-slider__nav--next"
          type="button"
          aria-label="Next slide"
        >
          <span>&rarr;</span>
        </button>
      {% endif %}

      {% if use_slider and section.settings.show_pagination %}
        <div class="supplement-hero-slider__pagination"></div>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .supplement-hero-slider {
    background: linear-gradient(
      to bottom,
      var(--shs-top-bg) 0,
      var(--shs-top-bg) var(--shs-bg-split),
      var(--shs-bottom-bg) var(--shs-bg-split),
      var(--shs-bottom-bg) 100%
    );
    padding-top: var(--shs-padding-top);
    padding-bottom: var(--shs-padding-bottom);
    overflow: hidden;
  }

  .supplement-hero-slider__inner {
    max-width: var(--shs-max-width);
    margin-inline: auto;
    padding-inline: var(--shs-padding-inline);
  }

  .supplement-hero-slider__swiper {
    position: relative;
  }

  .supplement-hero-slider__track {
    width: 100%;
  }

  .supplement-hero-slider__swiper--static .supplement-hero-slider__track {
    display: block;
  }

  .supplement-hero-slider__layout {
    min-height: var(--shs-min-height-desktop);
    display: grid;
    grid-template-columns: minmax(0, var(--shs-content-column)) minmax(0, var(--shs-media-column));
    gap: var(--shs-column-gap);
    align-items: center;
  }

  .supplement-hero-slider__content {
    max-width: var(--shs-content-width);
    position: relative;
    z-index: 2;
  }

  .supplement-hero-slider__content--left {
    text-align: left;
    justify-self: start;
  }

  .supplement-hero-slider__content--center {
    text-align: center;
    justify-self: center;
  }

  .supplement-hero-slider__content--right {
    text-align: right;
    justify-self: end;
  }

  .supplement-hero-slider__heading {
    margin: 0;
    color: var(--shs-heading-color);
    font-size: clamp(var(--shs-heading-size-mobile), 4.4vw, var(--shs-heading-size-desktop));
    font-weight: var(--shs-heading-weight);
    line-height: var(--shs-heading-line-height);
  }

  .supplement-hero-slider__subheading {
    margin: var(--shs-subheading-gap) 0 0;
    color: var(--shs-subheading-color);
    font-size: clamp(var(--shs-subheading-size-mobile), 1.6vw, var(--shs-subheading-size-desktop));
    font-weight: var(--shs-subheading-weight);
    line-height: var(--shs-subheading-line-height);
    text-transform: uppercase;
  }

  .supplement-hero-slider__description {
    margin-top: 12px;
    color: var(--shs-body-color);
    font-size: clamp(var(--shs-body-size-mobile), 1.2vw, var(--shs-body-size-desktop));
    font-weight: var(--shs-body-weight);
    line-height: var(--shs-body-line-height);
  }

  .supplement-hero-slider__description p {
    margin: 0;
  }

  .supplement-hero-slider__button {
    margin-top: var(--shs-button-gap);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: var(--shs-button-min-width);
    padding: var(--shs-button-padding-y) var(--shs-button-padding-x);
    border-radius: var(--shs-button-radius);
    border: 1px solid var(--shs-button-border);
    background: var(--shs-button-bg);
    color: var(--shs-button-text);
    text-decoration: none;
    text-transform: uppercase;
    font-size: var(--shs-button-size);
    font-weight: var(--shs-button-weight);
    line-height: 1;
    transition: background-color 0.25s ease, color 0.25s ease, border-color 0.25s ease;
  }

  .supplement-hero-slider__button:hover,
  .supplement-hero-slider__button:focus-visible {
    background: var(--shs-button-hover-bg);
    color: var(--shs-button-hover-text);
    border-color: var(--shs-button-hover-border);
  }

  .supplement-hero-slider__button--disabled {
    opacity: 0.75;
    pointer-events: none;
  }

  .supplement-hero-slider__media {
    display: flex;
    justify-content: var(--shs-block-media-horizontal, var(--shs-media-align));
    align-items: var(--shs-block-media-vertical, flex-end);
    min-width: 0;
    position: relative;
    transform: translateY(var(--shs-media-bottom-shift));
  }

  .supplement-hero-slider__media-track {
    width: 100%;
    max-width: var(--shs-media-max-width);
    display: flex;
    align-items: var(--shs-block-media-vertical, flex-end);
    justify-content: var(--shs-block-media-horizontal, flex-end);
  }

  .supplement-hero-slider__item {
    flex: 0 0 26%;
    min-width: 0;
    position: relative;
    z-index: 1;
    transform: translate(0, 0) scale(1);
    transform-origin: bottom center;
  }

  .supplement-hero-slider__item--1 {
    z-index: 2;
    transform: scale(0.88);
  }

  .supplement-hero-slider__item--2 {
    z-index: 4;
    transform: scale(1.1);
  }

  .supplement-hero-slider__item--3 {
    z-index: 3;
    transform: scale(0.94);
  }

  .supplement-hero-slider__item--4 {
    z-index: 1;
    transform: scale(0.85);
  }

  .supplement-hero-slider--figma .supplement-hero-slider__content {
    max-width: 520px;
  }

  .supplement-hero-slider--figma .supplement-hero-slider__heading {
    letter-spacing: 0;
  }

  .supplement-hero-slider--figma .supplement-hero-slider__subheading {
    max-width: 500px;
  }

  .supplement-hero-slider--figma .supplement-hero-slider__media-track {
    max-width: 1080px;
    justify-content: flex-end;
  }

  .supplement-hero-slider--figma .supplement-hero-slider__item {
    flex: 0 0 auto;
    margin-left: 0;
  }

  .supplement-hero-slider--figma .supplement-hero-slider__item--1 {
    width: 31%;
    z-index: 2;
    transform: scale(0.93);
    margin-left: 0;
  }

  .supplement-hero-slider--figma .supplement-hero-slider__item--2 {
    width: 38%;
    z-index: 4;
    transform: scale(1.08);
    margin-left: -15%;
  }

  .supplement-hero-slider--figma .supplement-hero-slider__item--3 {
    width: 32%;
    z-index: 3;
    transform: scale(0.96);
    margin-left: -16%;
  }

  .supplement-hero-slider--figma .supplement-hero-slider__item--4 {
    width: 29%;
    z-index: 1;
    transform: scale(0.88);
    margin-left: -14%;
  }

  .supplement-hero-slider__item:not(:first-child) {
    margin-left: calc(var(--shs-media-overlap) * -1);
  }

  .supplement-hero-slider__image {
    width: 100%;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .supplement-hero-slider__image--placeholder {
    background: rgba(0, 0, 0, 0.06);
    min-height: 180px;
  }

  .supplement-hero-slider__nav {
    width: var(--shs-nav-size);
    height: var(--shs-nav-size);
    border-radius: 999px;
    border: 1px solid var(--shs-nav-color);
    background: var(--shs-nav-bg);
    color: var(--shs-nav-color);
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 4;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .supplement-hero-slider__nav--prev {
    left: 0;
  }

  .supplement-hero-slider__nav--next {
    right: 0;
  }

  .supplement-hero-slider__pagination {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 12px;
    z-index: 4;
    display: flex;
    justify-content: center;
    gap: 8px;
  }

  .supplement-hero-slider__pagination .swiper-pagination-bullet {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.25);
    opacity: 1;
  }

  .supplement-hero-slider__pagination .swiper-pagination-bullet-active {
    background: var(--shs-nav-color);
  }

  @media screen and (max-width: 1199px) {
    .supplement-hero-slider__inner {
      padding-inline: max(16px, calc(var(--shs-padding-inline) * 0.8));
    }
  }

  @media screen and (max-width: 989px) {
    .supplement-hero-slider__layout {
      min-height: var(--shs-min-height-mobile);
      grid-template-columns: 1fr;
      align-items: flex-start;
      gap: clamp(22px, 5vw, var(--shs-column-gap));
    }

    .supplement-hero-slider--mobile-media-first .supplement-hero-slider__media {
      order: 1;
    }

    .supplement-hero-slider--mobile-media-first .supplement-hero-slider__content {
      order: 2;
    }

    .supplement-hero-slider--mobile-content-first .supplement-hero-slider__content {
      order: 1;
    }

    .supplement-hero-slider--mobile-content-first .supplement-hero-slider__media {
      order: 2;
    }

    .supplement-hero-slider__content {
      max-width: 100%;
    }

    .supplement-hero-slider__media {
      transform: translateY(calc(var(--shs-media-bottom-shift) * 0.5));
      justify-content: center;
    }

    .supplement-hero-slider__media-track {
      justify-content: center;
    }

    .supplement-hero-slider__item {
      flex-basis: 38%;
    }

    .supplement-hero-slider__item--1,
    .supplement-hero-slider__item--2,
    .supplement-hero-slider__item--3,
    .supplement-hero-slider__item--4 {
      transform: scale(1);
    }

    .supplement-hero-slider--figma .supplement-hero-slider__media-track {
      max-width: min(100%, 760px);
      justify-content: center;
    }

    .supplement-hero-slider--figma .supplement-hero-slider__item--1,
    .supplement-hero-slider--figma .supplement-hero-slider__item--2,
    .supplement-hero-slider--figma .supplement-hero-slider__item--3,
    .supplement-hero-slider--figma .supplement-hero-slider__item--4 {
      width: 40%;
      margin-left: -18%;
      transform: scale(1);
    }

    .supplement-hero-slider--figma .supplement-hero-slider__item--1 {
      margin-left: 0;
    }

    .supplement-hero-slider__nav {
      display: none;
    }
  }
{% endstylesheet %}

{% if use_slider %}
  <script>
    (function() {
      var root = document.getElementById('SupplementHeroSlider-{{ section.id }}');
      if (!root || root.dataset.swiperInited === 'true') return;

      function loadStyle(href, done) {
        if (document.querySelector('link[data-shs-swiper-css="true"]')) {
          done();
          return;
        }
        var link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = href;
        link.dataset.shsSwiperCss = 'true';
        link.onload = done;
        document.head.appendChild(link);
      }

      function loadScript(src, done) {
        if (window.Swiper) {
          done();
          return;
        }
        var existing = document.querySelector('script[data-shs-swiper-js="true"]');
        if (existing) {
          existing.addEventListener('load', done, { once: true });
          return;
        }
        var script = document.createElement('script');
        script.src = src;
        script.async = true;
        script.dataset.shsSwiperJs = 'true';
        script.onload = done;
        document.head.appendChild(script);
      }

      function init() {
        if (!window.Swiper) return;
        var el = root.querySelector('.supplement-hero-slider__swiper.swiper');
        if (!el) return;

        var config = {
          slidesPerView: 1,
          speed: {{ section.settings.slider_speed }},
          spaceBetween: 0,
          loop: {% if section.settings.loop %}true{% else %}false{% endif %}
        };

        {% if section.settings.autoplay %}
          config.autoplay = {
            delay: {{ section.settings.autoplay_delay }},
            disableOnInteraction: false
          };
        {% endif %}

        {% if section.settings.show_navigation %}
          config.navigation = {
            prevEl: root.querySelector('.supplement-hero-slider__nav--prev'),
            nextEl: root.querySelector('.supplement-hero-slider__nav--next')
          };
        {% endif %}

        {% if section.settings.show_pagination %}
          config.pagination = {
            el: root.querySelector('.supplement-hero-slider__pagination'),
            clickable: true
          };
        {% endif %}

        new Swiper(el, config);
        root.dataset.swiperInited = 'true';
      }

      loadStyle('https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css', function() {
        loadScript('https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js', init);
      });
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Supplement hero slider",
  "tag": "section",
  "class": "section-supplement-hero-slider",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "enable_slider",
      "label": "Enable slider when multiple slides",
      "default": true
    },
    {
      "type": "select",
      "id": "mobile_order",
      "label": "Mobile order",
      "options": [
        { "value": "content-first", "label": "Content first" },
        { "value": "media-first", "label": "Images first" }
      ],
      "default": "content-first"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
