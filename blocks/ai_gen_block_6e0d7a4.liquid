{% doc %}
  @prompt
    Create Block using this I can add collection card settings and give me option int his related set image, round corner, colum,  heading size, all colors , paddings, image custom add if not select it would add collection image default, image ratio, collection name position ex: in image or outside image also overlay text on image etc.. like this all functionality and with well design.

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-card-wrapper-{{ ai_gen_id }} {
    padding: {{ block.settings.padding }}px;
  }

  .ai-collection-card-{{ ai_gen_id }} {
    position: relative;
    height: 100%;
    background-color: {{ block.settings.card_background_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 {{ block.settings.shadow_y_offset }}px {{ block.settings.shadow_blur }}px rgba({{ block.settings.shadow_color | color_to_rgb }}, {{ block.settings.shadow_opacity | divided_by: 100.0 }});
    transition: transform 0.3s ease;
  }

  .ai-collection-card-image-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    {% if block.settings.title_position != 'overlay' %}
      border-radius: {{ block.settings.card_border_radius }}px {{ block.settings.card_border_radius }}px 0 0;
    {% else %}
      border-radius: {{ block.settings.card_border_radius }}px;
    {% endif %}
  }

  .ai-collection-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 0;
    padding-bottom: {{ block.settings.image_ratio }}%;
    position: relative;
    overflow: hidden;
  }

  .ai-collection-card-image-{{ ai_gen_id }} img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .ai-collection-card-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.placeholder_background_color }};
  }

  .ai-collection-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    fill: {{ block.settings.placeholder_icon_color }};
  }

  {% if block.settings.image_hover_effect == 'zoom' %}
    .ai-collection-card-{{ ai_gen_id }}:hover .ai-collection-card-image-{{ ai_gen_id }} img {
      transform: scale(1.05);
    }
  {% endif %}

  .ai-collection-card-content-{{ ai_gen_id }} {
    {% if block.settings.title_position == 'below' %}
      padding: {{ block.settings.content_padding }}px;
    {% endif %}
  }

  .ai-collection-card-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.overlay_vertical_alignment }};
    align-items: {{ block.settings.overlay_horizontal_alignment }};
    padding: {{ block.settings.content_padding }}px;
    background: linear-gradient(
      {{ block.settings.overlay_gradient_direction }}deg,
      {{ block.settings.overlay_color | color_to_rgb | replace: 'rgb', 'rgba' | replace: ')', ', ' }}{{ block.settings.overlay_opacity | divided_by: 100.0 }}),
      {{ block.settings.overlay_color_secondary | color_to_rgb | replace: 'rgb', 'rgba' | replace: ')', ', ' }}{{ block.settings.overlay_opacity_secondary | divided_by: 100.0 }})
    );
    pointer-events: none;
  }

  .ai-collection-card-title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    text-align: {{ block.settings.text_alignment }};
    {% if block.settings.title_text_shadow %}
      text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    {% endif %}
  }

  .ai-collection-card-description-{{ ai_gen_id }} {
    margin-top: 8px;
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    text-align: {{ block.settings.text_alignment }};
    {% if block.settings.title_position == 'overlay' and block.settings.title_text_shadow %}
      text-shadow: 0 1px 3px rgba(0, 0, 0, 0.3);
    {% endif %}
  }

  .ai-collection-card-button-{{ ai_gen_id }} {
    display: inline-block;
    margin-top: 16px;
    padding: 8px 16px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.button_font_size }}px;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    text-align: center;
    transition: background-color 0.3s ease;
    pointer-events: auto;
  }

  .ai-collection-card-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_background_hover_color }};
    color: {{ block.settings.button_text_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-collection-grid-{{ ai_gen_id }} {
      display: grid;
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.gap }}px;
    }
    
    .ai-collection-card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }
    
    .ai-collection-card-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.8 }}px;
    }
  }

  @media screen and (min-width: 750px) {
    .ai-collection-grid-{{ ai_gen_id }} {
      display: grid;
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
      gap: {{ block.settings.gap }}px;
    }
  }
{% endstyle %}

<div class="ai-collection-card-wrapper-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 style="
      font-size: {{ block.settings.heading_size }}px;
      color: {{ block.settings.heading_color }};
      text-align: {{ block.settings.heading_alignment }};
      margin-bottom: {{ block.settings.heading_margin_bottom }}px;
    ">
      {{ block.settings.heading }}
    </h2>
  {% endif %}

  <div class="ai-collection-grid-{{ ai_gen_id }}">
    {% for collection in block.settings.collections %}
      <div class="ai-collection-card-wrapper-item-{{ ai_gen_id }}">
        <a href="{{ collection.url }}" class="ai-collection-card-{{ ai_gen_id }}">
          <div class="ai-collection-card-image-container-{{ ai_gen_id }}">
            <div class="ai-collection-card-image-{{ ai_gen_id }}">
              {% if block.settings.custom_image != blank and block.settings.use_custom_image %}
                <img 
                  src="{{ block.settings.custom_image | image_url: width: 1000 }}"
                  alt="{{ collection.title | escape }}"
                  loading="lazy"
                  width="{{ block.settings.custom_image.width }}"
                  height="{{ block.settings.custom_image.height }}"
                >
              {% elsif collection.image %}
                <img 
                  src="{{ collection.image | image_url: width: 1000 }}"
                  alt="{{ collection.title | escape }}"
                  loading="lazy"
                  width="{{ collection.image.width }}"
                  height="{{ collection.image.height }}"
                >
              {% else %}
                <div class="ai-collection-card-image-placeholder-{{ ai_gen_id }}">
                  {{ 'collection-apparel-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            {% if block.settings.title_position == 'overlay' %}
              <div class="ai-collection-card-overlay-{{ ai_gen_id }}">
                <div class="ai-collection-card-content-{{ ai_gen_id }}">
                  <h3 class="ai-collection-card-title-{{ ai_gen_id }}">{{ collection.title }}</h3>
                  
                  {% if block.settings.show_description and collection.description != blank %}
                    <div class="ai-collection-card-description-{{ ai_gen_id }}">
                      {{ collection.description | strip_html | truncate: block.settings.description_length }}
                    </div>
                  {% endif %}
                  
                  {% if block.settings.show_button %}
                    <span class="ai-collection-card-button-{{ ai_gen_id }}">{{ block.settings.button_text }}</span>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          </div>

          {% if block.settings.title_position == 'below' %}
            <div class="ai-collection-card-content-{{ ai_gen_id }}">
              <h3 class="ai-collection-card-title-{{ ai_gen_id }}">{{ collection.title }}</h3>
              
              {% if block.settings.show_description and collection.description != blank %}
                <div class="ai-collection-card-description-{{ ai_gen_id }}">
                  {{ collection.description | strip_html | truncate: block.settings.description_length }}
                </div>
              {% endif %}
              
              {% if block.settings.show_button %}
                <span class="ai-collection-card-button-{{ ai_gen_id }}">{{ block.settings.button_text }}</span>
              {% endif %}
            </div>
          {% endif %}
        </a>
      </div>
    {% endfor %}
  </div>
</div>

