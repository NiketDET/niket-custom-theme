{% doc %}
  @prompt
    Create countdown banner like it should show me text, heading, button., Countdown not working properly

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-countdown-banner-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    padding: {{ block.settings.padding }}px;
    text-align: {{ block.settings.text_alignment }};
    position: relative;
    overflow: hidden;
    margin: 0 auto;
  }

  .ai-countdown-banner__content-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: {% if block.settings.text_alignment == 'center' %}center{% elsif block.settings.text_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
  }

  .ai-countdown-banner__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    margin: 0;
    color: {{ block.settings.heading_color }};
  }

  .ai-countdown-banner__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    margin: 0;
    opacity: 0.9;
  }

  .ai-countdown-banner__timer-{{ ai_gen_id }} {
    display: flex;
    gap: 0px;
    margin: 8px 0;
    flex-wrap: wrap;
    justify-content: {% if block.settings.text_alignment == 'center' %}center{% elsif block.settings.text_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
    align-items: center;
  }
    span.countdown-coluns {
        font-size: 50px;
        color: #fcd34d;
    }
  .ai-countdown-banner__timer-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    background-color: {{ block.settings.timer_background }};
    color: {{ block.settings.timer_text_color }};
    padding: 12px 10px;
    border-radius: {{ block.settings.timer_border_radius }}px;
    min-width: 60px;
  }

  .ai-countdown-banner__timer-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.timer_number_size }}px;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 4px;
  }

  .ai-countdown-banner__timer-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.timer_label_size }}px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    opacity: 0.8;
  }

  .ai-countdown-banner__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 24px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    font-size: 16px;
  }

  .ai-countdown-banner__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    transform: translateY(-2px);
  }

  .ai-countdown-banner__expired-{{ ai_gen_id }} {
    display: none;
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.expired_text_color }};
    font-weight: 600;
  }

  @media screen and (max-width: 749px) {
    .ai-countdown-banner__content-{{ ai_gen_id }} {
      text-align: center;align-items: center;
    }

    .ai-countdown-banner__timer-{{ ai_gen_id }} {
      justify-content: center;gap: 8px;
    }

    .ai-countdown-banner__timer-item-{{ ai_gen_id }} {
      padding: 8px 12px;
      min-width: 50px;
    }

    .ai-countdown-banner__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }
  }
  @media screen and (max-width: 500px) {
    .ai-countdown-banner__timer-item-azupxuzrvdfnjuctesaigenblock4e8574byea3xn {
        padding: 8px 8px;
    }
    .ai-countdown-banner__text-azupxuzrvdfnjuctesaigenblock4e8574byea3xn {
      font-size: 16px;
    }
    .ai-countdown-banner__timer-number-azupxuzrvdfnjuctesaigenblock4e8574byea3xn {
      font-size: 25px;
    }
  }
{% endstyle %}

<countdown-banner-{{ ai_gen_id }}
  class="ai-countdown-banner-{{ ai_gen_id }}"
  data-end-date="{{ block.settings.end_date }}"
  data-end-time="{{ block.settings.end_time }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-countdown-banner__content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-countdown-banner__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.text != blank %}
      <p class="ai-countdown-banner__text-{{ ai_gen_id }}">{{ block.settings.text }}</p>
    {% endif %}

    <div class="ai-countdown-banner__timer-{{ ai_gen_id }}" id="timer-{{ ai_gen_id }}">
      <div class="ai-countdown-banner__timer-item-{{ ai_gen_id }}">
        <div class="ai-countdown-banner__timer-number-{{ ai_gen_id }}" data-days>00</div>
        <div class="ai-countdown-banner__timer-label-{{ ai_gen_id }}">Days</div>
      </div>
      <span class="countdown-coluns">:</span>
      <div class="ai-countdown-banner__timer-item-{{ ai_gen_id }}">
        <div class="ai-countdown-banner__timer-number-{{ ai_gen_id }}" data-hours>00</div>
        <div class="ai-countdown-banner__timer-label-{{ ai_gen_id }}">Hours</div>
      </div>
      <span class="countdown-coluns">:</span>
      <div class="ai-countdown-banner__timer-item-{{ ai_gen_id }}">
        <div class="ai-countdown-banner__timer-number-{{ ai_gen_id }}" data-minutes>00</div>
        <div class="ai-countdown-banner__timer-label-{{ ai_gen_id }}">Minutes</div>
      </div>
      <span class="countdown-coluns">:</span>
      <div class="ai-countdown-banner__timer-item-{{ ai_gen_id }}">
        <div class="ai-countdown-banner__timer-number-{{ ai_gen_id }}" data-seconds>00</div>
        <div class="ai-countdown-banner__timer-label-{{ ai_gen_id }}">Seconds</div>
      </div>
    </div>

    <div class="ai-countdown-banner__expired-{{ ai_gen_id }}" id="expired-{{ ai_gen_id }}">
      {{ block.settings.expired_message }}
    </div>

    {% if block.settings.button_text != blank and block.settings.button_url != blank %}
      <a href="{{ block.settings.button_url }}" class="ai-countdown-banner__button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</countdown-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class CountdownBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.timer = null;
        this.endDateTime = null;
      }

      connectedCallback() {
        this.initializeCountdown();
      }

      disconnectedCallback() {
        if (this.timer) {
          clearInterval(this.timer);
        }
      }

      initializeCountdown() {
        const endDate = this.dataset.endDate;
        const endTime = this.dataset.endTime || '23:59:59';
        
        if (!endDate) {
          console.error('End date is required for countdown');
          this.showExpired();
          return;
        }

        const dateTimeString = endDate + 'T' + endTime;
        this.endDateTime = new Date(dateTimeString);

        if (isNaN(this.endDateTime.getTime())) {
          console.error('Invalid date format. Use YYYY-MM-DD for date and HH:MM:SS for time');
          this.showExpired();
          return;
        }

        this.startCountdown();
      }

      startCountdown() {
        this.updateDisplay();
        
        this.timer = setInterval(() => {
          this.updateDisplay();
        }, 1000);
      }

      updateDisplay() {
        const now = new Date().getTime();
        const distance = this.endDateTime.getTime() - now;

        if (distance < 0) {
          this.showExpired();
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        this.updateElement('[data-days]', days);
        this.updateElement('[data-hours]', hours);
        this.updateElement('[data-minutes]', minutes);
        this.updateElement('[data-seconds]', seconds);
      }

      updateElement(selector, value) {
        const element = this.querySelector(selector);
        if (element) {
          element.textContent = String(value).padStart(2, '0');
        }
      }

      showExpired() {
        if (this.timer) {
          clearInterval(this.timer);
          this.timer = null;
        }
        
        const timerElement = this.querySelector('#timer-{{ ai_gen_id }}');
        const expiredElement = this.querySelector('#expired-{{ ai_gen_id }}');
        
        if (timerElement) {
          timerElement.style.display = 'none';
        }
        if (expiredElement) {
          expiredElement.style.display = 'block';
        }
      }
    }

    customElements.define('countdown-banner-{{ ai_gen_id }}', CountdownBanner{{ ai_gen_id }});
  })();
</script>

